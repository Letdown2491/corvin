{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Corvin",
  "version": "1.0.0-rc1",
  "identifier": "dev.corvin.wallet",
  "build": {
    "frontendDist": "./splash"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Finance",
    "shortDescription": "Self-hosted Bitcoin wallet",
    "longDescription": "Corvin is a self-hosted Bitcoin wallet packaged as a single desktop binary.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist"
    }
  }
}
